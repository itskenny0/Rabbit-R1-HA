<?xml version="1.0" encoding="utf-8"?>
<!--
  Bold orange rabbit silhouette — round head + two upright ears — centred inside the adaptive
  icon's circular safe zone (radius ~36 from centre). Everything fits within an r=22 circle at
  (54, 64) for the head and 10dp-wide pills at y∈[22, 54] for the ears, so the mark survives
  any launcher mask (square, rounded square, circle, squircle) without losing its identity.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp" android:height="108dp"
    android:viewportWidth="108" android:viewportHeight="108">

    <!-- Head: r=22 circle centred at (54, 64). Four cubic bezier segments approximate the
         circle via the standard 0.5523 control-point offset. -->
    <path android:fillColor="#F36F21"
        android:pathData="M54,42 C66.15,42 76,51.85 76,64 C76,76.15 66.15,86 54,86 C41.85,86 32,76.15 32,64 C32,51.85 41.85,42 54,42 Z"/>

    <!-- Left ear: rounded pill from (40,22)…(50,54), tip rounded with cubic beziers, base
         tucks into the head circle (overlap intentional). -->
    <path android:fillColor="#F36F21"
        android:pathData="M40,28 C40,24 42,22 45,22 C48,22 50,24 50,28 L50,54 L40,54 Z"/>

    <!-- Right ear: mirror of the left. -->
    <path android:fillColor="#F36F21"
        android:pathData="M58,28 C58,24 60,22 63,22 C66,22 68,24 68,28 L68,54 L58,54 Z"/>
</vector>
